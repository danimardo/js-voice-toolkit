{
  "name": "js-voice-toolkit",
  "version": "0.1.0",
  "description": "Librería agnóstica de framework para TTS (ElevenLabs) y STT (Mistral Voxtral)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["tts", "stt", "elevenlabs", "voxtral", "mistral", "speech"],
  "license": "MIT"
}
